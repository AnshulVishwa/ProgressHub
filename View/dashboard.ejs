<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Progress Hub: Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#0f172a] text-gray-100 font-sans min-h-screen">

    <nav class="w-full bg-[#1e293b] p-4 flex justify-between items-center shadow-lg border-b border-gray-700 sticky top-0 z-50">
        <div class="text-2xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500 tracking-wide">
            ProgressHub
        </div>
        <div class="flex gap-3 flex-wrap justify-end">
            <a href="/<%= username %>" class="text-gray-200 bg-[#334155]/60 hover:bg-white/10 px-4 py-2 rounded-xl font-medium text-sm transition-all border border-white/5 flex items-center gap-2">
                💻 DSA Dashboard
            </a>
            <a href="/timetable/dashboard/<%= username %>" class="text-blue-400 bg-blue-500/10 border-blue-400/30 px-4 py-2 rounded-xl font-medium text-sm transition-all flex items-center gap-2">
                📊 Timetable Dashboard
            </a>
            <a href="/timetable/<%= username %>" class="text-gray-200 bg-[#334155]/60 hover:bg-white/10 px-4 py-2 rounded-xl font-medium text-sm transition-all border border-white/5 flex items-center gap-2">
                🗓️ Timetable
            </a>
            <a href="/<%= username %>/newday" class="text-gray-200 bg-[#334155]/60 hover:bg-white/10 px-4 py-2 rounded-xl font-medium text-sm transition-all border border-white/5 flex items-center gap-2">
                ➕ Log New Day
            </a>
            <a href="/<%= username %>/update" class="text-gray-200 bg-[#334155]/60 hover:bg-white/10 px-4 py-2 rounded-xl font-medium text-sm transition-all border border-white/5 flex items-center gap-2">
                🔄 Update Day
            </a>
            <a href="/" class="text-gray-200 bg-[#334155]/60 hover:bg-white/10 px-4 py-2 rounded-xl font-medium text-sm transition-all border border-white/5 flex items-center gap-2">
                🚪 Switch User
            </a>
        </div>
    </nav>

    <div class="p-6">
    <div class="max-w-6xl mx-auto">
        <!-- Header Section -->
        <div class="flex justify-between items-center mb-10 mt-4">
            <h1 class="text-3xl font-bold text-white">Analytics Dashboard 📊</h1>
            <a href="/timetable/<%= username %>"
                class="bg-gray-700 hover:bg-gray-600 text-white py-2 px-4 rounded-lg transition">
                ✏️ Edit Timetable
            </a>
        </div>

        <!-- Top Stats Row -->
        <div class="grid grid-cols-1 gap-6 mb-10">
            <!-- Total Hours Card -->
            <div
                class="bg-gradient-to-r from-blue-600 to-cyan-500 p-6 rounded-xl shadow-lg flex items-center justify-between">
                <div>
                    <h2 class="text-xl font-semibold text-white/90">Total Hours Logged</h2>
                    <p class="text-4xl font-bold text-white mt-2">
                        <%= totalHoursLogged %> hrs
                    </p>
                </div>
                <div class="text-6xl">⏱️</div>
            </div>
        </div>

        <!-- Subject Progress Cards Grid -->
        <h2 class="text-2xl font-semibold mb-6 text-gray-300">Subject Progress 📚</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% if (subjectProgressList && subjectProgressList.length> 0) { %>
                <% subjectProgressList.forEach(subject=> { %>
                    <!-- Individual Subject Card -->
                    <div
                        class="bg-[#1e293b] p-6 rounded-xl shadow-lg border border-gray-700 hover:border-blue-500 transition-colors">
                        <div class="flex justify-between items-start mb-4">
                            <h3 class="text-xl font-bold text-white">
                                <%= subject.name %>
                            </h3>
                            <span class="text-xs font-semibold px-2 py-1 bg-gray-700 rounded-full text-blue-400">
                                <%= subject.spent %> / <%= subject.target %> hrs
                            </span>
                        </div>

                        <!-- Progress Bar Container -->
                        <div class="w-full bg-gray-800 rounded-full h-3 mb-2 overflow-hidden border border-gray-700">
                            <!-- Dynamic Progress Bar Fill -->
                            <div class="bg-blue-500 h-3 rounded-full transition-all duration-1000 ease-out"
                                style="width: <%= subject.progressPercentage %>%">
                            </div>
                        </div>

                        <p class="text-right text-sm text-gray-400 mt-1">
                            <%= Math.round(subject.progressPercentage) %>% Completed 🎯
                        </p>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <p class="text-gray-400 col-span-full">No progress data found yet! Go log some hours! 🏃‍♂️
                            </p>
                            <% } %>
        </div>

    </div>
    </div>

</body>

</html>