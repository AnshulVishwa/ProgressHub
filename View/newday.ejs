<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log New Day - ProgressHub</title>

    <style>
        /* 🎨 Clean Dark Theme Variables */
        :root {
            --bg-main: #131426;
            --bg-card: #1c1d36;
            --bg-nav-button: #242645;
            --bg-input: #15162c;

            --text-main: #ffffff;
            --text-muted: #8a8ca3;

            --accent-brand: #9d7cff;
            --accent-hover: #b095ff;

            --border-color: rgba(255, 255, 255, 0.08);
            --border-focus: rgba(157, 124, 255, 0.5);
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* 🧭 Standard Top Navbar */
        .dashboard-nav {
            width: 100%;
            background-color: var(--bg-main);
            padding: 1.2rem 4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-sizing: border-box;
            border-bottom: 1px solid var(--border-color);
        }

        .brand-title {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--accent-brand);
            letter-spacing: 0.5px;
            text-decoration: none;
        }

        .navigation-links a {
            text-decoration: none;
            color: var(--text-main);
            background: var(--bg-nav-button);
            padding: 0.5rem 1.2rem;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: background 0.2s ease;
            border: 1px solid var(--border-color);
        }

        .navigation-links a:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        /* 📦 Form Container */
        .form-wrapper {
            width: 100%;
            max-width: 650px;
            /* Slightly tighter since there are no side-by-side dynamic buttons */
            padding: 3rem 2rem;
            box-sizing: border-box;
        }

        .form-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .form-header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin: 0;
            color: var(--text-main);
        }

        .form-header p {
            color: var(--text-muted);
            margin-top: 0.5rem;
        }

        /* 🃏 Flat Dark Form Card */
        .log-day-form {
            background-color: var(--bg-card);
            border-radius: 16px;
            padding: 2.5rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            border: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            gap: 1.8rem;
        }

        /* 📝 Input Styling */
        .input-group {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .input-label {
            font-weight: 600;
            color: var(--text-muted);
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .base-input {
            background-color: var(--bg-input);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 1rem;
            border-radius: 8px;
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
            font-family: inherit;
            width: 100%;
            box-sizing: border-box;
        }

        .base-input:focus {
            border-color: var(--border-focus);
            box-shadow: 0 0 0 3px rgba(157, 124, 255, 0.15);
        }

        /* 🔽 Custom Multi-Select */
        select[multiple] {
            height: 180px;
            padding: 0.5rem;
        }

        select[multiple] option {
            padding: 0.8rem 1rem;
            margin-bottom: 2px;
            border-radius: 4px;
            cursor: pointer;
        }

        select[multiple] option:checked {
            background-color: var(--accent-brand);
            color: white;
        }

        select:not([multiple]) option {
            background-color: var(--bg-card);
        }

        /* 🔄 Flex row for Question + Difficulty */
        .question-row {
            display: flex;
            gap: 1rem;
        }

        .question-input {
            flex: 2;
        }

        .difficulty-select {
            flex: 1;
        }

        /* 🚀 Submit Button */
        .btn-submit {
            background-color: var(--accent-brand);
            color: #ffffff;
            padding: 1rem;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            border: none;
            transition: background 0.3s ease, transform 0.2s ease;
            margin-top: 0.5rem;
        }

        .btn-submit:hover {
            background-color: var(--accent-hover);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(157, 124, 255, 0.3);
        }
    </style>
</head>

<body>
    <nav class="dashboard-nav">
        <a href="/<%= username %>" class="brand-title">ProgressHub</a>
        <div class="navigation-links">
            <a href="/<%= username %>">⬅️ Back to Dashboard</a>
        </div>
    </nav>

    <div class="form-wrapper">
        <header class="form-header">
            <h1>Log a New Day 🚀</h1>
            <p>Keep the streak alive, <%= username %>!</p>
        </header>

        <form class="log-day-form" action="/<%= username %>/newday" method="POST">

            <div class="input-group">
                <label class="input-label">Topics Covered 📚 (Hold Ctrl/Cmd to select multiple)</label>
                <select name="topics[]" multiple class="base-input" required>
                    <option value="Arrays">Arrays</option>
                    <option value="Strings">Strings</option>
                    <option value="Numbers">Numbers</option>
                    <option value="Linked Lists">Linked Lists</option>
                    <option value="Stacks">Stacks</option>
                    <option value="Queues">Queues</option>
                    <option value="HashMaps">HashMaps</option>
                    <option value="Trees">Trees</option>
                    <option value="Graphs">Graphs</option>
                    <option value="Heaps">Heaps / Priority Queues</option>
                    <option value="Matrices">Matrices</option>
                    <option value="Dynamic Programming">Dynamic Programming</option>
                    <option value="Math">Math</option>
                </select>
            </div>

            <div class="input-group">
                <label class="input-label">Day Number 📅</label>
                <input type="number" name="day" class="base-input" placeholder="e.g. 4" required>
            </div>

            <div class="input-group">
                <label class="input-label">LeetCode Number 🔢</label>
                <input type="number" name="leetcodeNum[]" class="base-input" placeholder="e.g. 1" required>
            </div>

            <div class="input-group">
                <label class="input-label">Question Solved 💡</label>
                <div class="question-row">
                    <input type="text" name="questions[0][q]" class="base-input question-input"
                        placeholder="Question Title (e.g. Two Sum)" required>
                    <select name="questions[0][difficulty]" class="base-input difficulty-select" required>
                        <option value="Easy">Easy 🟢</option>
                        <option value="Medium">Medium 🟡</option>
                        <option value="Hard">Hard 🔴</option>
                    </select>
                </div>
            </div>

            <div class="input-group">
                <label class="input-label">Algorithm Implemented ⚙️</label>
                <input type="text" name="algorithms[]" class="base-input" placeholder="e.g. Binary Search" required>
            </div>

            <button type="submit" class="btn-submit">💾 Save Progress</button>
        </form>
    </div>
</body>

</html>