<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Details - ProgressHub</title>

    <style>
        /* 🎨 Clean Dark Theme Variables (Perfect Match with Home & New Day!) */
        :root {
            --bg-main: #131426;
            --bg-card: #1c1d36;
            --bg-nav-button: #242645;
            --bg-input: #15162c;

            --text-main: #ffffff;
            --text-muted: #8a8ca3;

            --accent-brand: #9d7cff;
            --accent-hover: #b095ff;
            --update-accent: #3b82f6;
            /* Keeping a blue tint for the update action! */

            --border-color: rgba(255, 255, 255, 0.08);
            --border-focus: rgba(59, 130, 246, 0.5);
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* 🧭 Standard Top Navbar */
        .dashboard-nav {
            width: 100%;
            background-color: var(--bg-main);
            padding: 1.2rem 4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-sizing: border-box;
            border-bottom: 1px solid var(--border-color);
        }

        .brand-title {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--accent-brand);
            letter-spacing: 0.5px;
            text-decoration: none;
        }

        .navigation-links {
            display: flex;
            gap: 1rem;
        }

        .navigation-links a {
            text-decoration: none;
            color: var(--text-main);
            background: var(--bg-nav-button);
            padding: 0.5rem 1.2rem;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: background 0.2s ease;
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .navigation-links a:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        /* 📦 Form Container */
        .form-wrapper {
            width: 100%;
            max-width: 600px;
            /* Slightly narrower than New Day since it's a single update */
            padding: 3rem 2rem;
            box-sizing: border-box;
        }

        .form-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .form-header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin: 0;
            color: var(--text-main);
        }

        .form-header p {
            color: var(--text-muted);
            margin-top: 0.5rem;
        }

        /* 🃏 Flat Dark Form Card */
        .update-form {
            background-color: var(--bg-card);
            border-radius: 16px;
            padding: 2.5rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            border: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* 📝 Input Group Styling */
        .input-group {
            display: flex;
            flex-direction: column;
            gap: 0.6rem;
        }

        .input-label {
            font-weight: 600;
            color: var(--text-muted);
            font-size: 0.8rem;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .base-input {
            background-color: var(--bg-input);
            border: 1px solid var(--border-color);
            color: var(--text-main);
            padding: 0.8rem 1rem;
            border-radius: 8px;
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
            font-family: inherit;
            width: 100%;
            box-sizing: border-box;
        }

        .base-input:focus {
            border-color: var(--border-focus);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
        }

        select.base-input option {
            background-color: var(--bg-card);
            color: var(--text-main);
        }

        /* 🚀 Submit Button Styling */
        .btn-submit {
            background-color: var(--update-accent);
            color: #ffffff;
            padding: 1rem;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
            margin-top: 1rem;
        }

        .btn-submit:hover {
            background-color: #2563eb;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(59, 130, 246, 0.3);
        }
    </style>
</head>

<body>
    <nav class="dashboard-nav">
        <a href="/<%= username %>" class="brand-title">ProgressHub</a>
        <div class="navigation-links">
            <a href="/<%= username %>">🏠 Dashboard</a>
            <a href="/<%= username %>/newday">➕ Log New Day</a>
            <a href="/login">🚪 Switch User</a>
        </div>
    </nav>

    <div class="form-wrapper">
        <header class="form-header">
            <h1>Update Progress 🔄</h1>
            <p>Add more achievements to your existing day!</p>
        </header>

        <form class="update-form" method="POST" action="/<%= username %>/update">

            <div class="input-group">
                <label class="input-label" for="day">Day Number 📅</label>
                <input type="number" id="day" name="day" class="base-input" placeholder="e.g. 1" required>
            </div>

            <div class="input-group">
                <label class="input-label" for="topics">Topic Covered 📚</label>
                <select id="topics" name="topics[]" class="base-input" required>
                    <option value="" disabled selected>Select a topic...</option>
                    <option value="Strings">Strings</option>
                    <option value="Numbers">Numbers</option>
                    <option value="Arrays">Arrays</option>
                    <option value="Linked Lists">Linked Lists</option>
                    <option value="Stacks">Stacks</option>
                    <option value="Queues">Queues</option>
                    <option value="HashMaps">HashMaps</option>
                    <option value="Trees">Trees</option>
                    <option value="Graphs">Graphs</option>
                    <option value="Heaps">Heaps / Priority Queues</option>
                    <option value="Matrices">Matrices</option>
                    <option value="Dynamic Programming">Dynamic Programming</option>
                    <option value="Math">Math</option>
                </select>
            </div>

            <div class="input-group">
                <label class="input-label" for="questions">Question Solved 💡</label>
                <input type="text" id="questions" name="questions[0][q]" class="base-input"
                    placeholder="e.g. Merge Intervals" required>
            </div>

            <div class="input-group">
                <label class="input-label" for="difficulty">Difficulty Level 🎯</label>
                <select id="difficulty" name="questions[0][difficulty]" class="base-input" required>
                    <option value="Easy">Easy 🟢</option>
                    <option value="Medium">Medium 🟡</option>
                    <option value="Hard">Hard 🔴</option>
                </select>
            </div>

            <div class="input-group">
                <label class="input-label" for="leetcodeNum">LeetCode Number 🔢</label>
                <input type="number" id="leetcodeNum" name="leetcodeNum[]" class="base-input" placeholder="e.g. 56">
            </div>

            <div class="input-group">
                <label class="input-label" for="algorithms">Algorithm Implemented ⚙️</label>
                <input type="text" id="algorithms" name="algorithms[]" class="base-input" placeholder="e.g. Sorting"
                    required>
            </div>

            <button type="submit" class="btn-submit">🚀 Update Today's Day</button>
        </form>
    </div>
</body>

</html>