<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update Details</title>
    <style>
        /* 🎨 Perfect consistency with your New Day form! */
        :root {
            --bg-gradient: linear-gradient(135deg, #0f172a, #1e1b4b);
            --card-bg: rgba(255, 255, 255, 0.05);
            --card-border: rgba(255, 255, 255, 0.1);
            --input-bg: rgba(255, 255, 255, 0.08);
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --accent: #8b5cf6;
            --accent-hover: #a855f7;
            --update-accent: #3b82f6;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--bg-gradient);
            color: var(--text-main);
            min-height: 100vh;
            /* Changed to column so the navbar stays at the top! 📏 */
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* 🧭 Glassmorphism Navbar */
        .navbar {
            width: 100%;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--card-border);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-sizing: border-box;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-brand {
            font-size: 1.5rem;
            font-weight: 800;
            background: linear-gradient(to right, #3b82f6, #a855f7);
            /* Matched update gradient! */
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
        }

        .nav-links {
            display: flex;
            gap: 1rem;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-main);
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.2s ease;
        }

        .nav-links a:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }

        /* 🪟 The Glassmorphism Container */
        .form-container {
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            padding: 3rem;
            width: 100%;
            max-width: 450px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
            /* margin: auto keeps it perfectly centered! 🎯 */
            margin: auto;
            margin-top: 3rem;
            margin-bottom: 3rem;
        }

        .form-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .form-header h2 {
            margin: 0;
            font-size: 2rem;
            background: linear-gradient(to right, #3b82f6, #a855f7);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .form-header p {
            color: var(--text-muted);
            margin-top: 0.5rem;
            font-size: 0.95rem;
        }

        /* 📝 Input Group Styling */
        .input-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
            color: var(--text-muted);
            letter-spacing: 0.5px;
        }

        input[type="text"],
        select {
            width: 100%;
            padding: 12px 16px;
            background: var(--input-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            color: var(--text-main);
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
            box-sizing: border-box;
        }

        /* ✨ Focus Effects */
        input[type="text"]:focus,
        select:focus {
            border-color: var(--update-accent);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
            background: rgba(255, 255, 255, 0.12);
        }

        select option {
            background-color: #1e1b4b;
            color: var(--text-main);
        }

        /* 🚀 Submit Button Styling */
        button {
            width: 100%;
            padding: 14px;
            margin-top: 1rem;
            background: linear-gradient(135deg, var(--update-accent), var(--accent));
            border: none;
            border-radius: 12px;
            color: white;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
        }

        button:active {
            transform: translateY(1px);
        }
    </style>
</head>

<body>
    <nav class="navbar">
        <a href="/<%= username %>" class="nav-brand">ProgressHub</a>
        <div class="nav-links">
            <a href="/<%= username %>">🏠 Dashboard</a>
            <a href="/<%= username %>/newday">➕ Log New Day</a>
            <a href="/<%= username %>/update">🔄 Update Day</a>
            <a href="/login">🚪 Switch User</a>
        </div>
    </nav>

    <div class="form-container">
        <div class="form-header">
            <h2>Update Progress 🔄</h2>
            <p>Add more achievements to your day!</p>
        </div>

        <form method="POST" action="/<%= username %>/update">
            <div class="input-group">
                <label for="day">Day Number 📅</label>
                <input type="text" id="day" name="day" placeholder="e.g., 1" required>
            </div>

            <div class="input-group">
                <label for="topics">Topic Covered 📚</label>
                <select id="topics" name="topics" required>
                    <option value="" disabled selected>Select a topic...</option>
                    <option value="Arrays">Arrays</option>
                    <option value="Linked Lists">Linked Lists</option>
                    <option value="Stacks & Queues">Stacks & Queues</option>
                    <option value="Hash Tables">Hash Tables / Maps</option>
                    <option value="Trees">Trees (Binary, BST, etc.)</option>
                    <option value="Graphs">Graphs</option>
                    <option value="Heaps">Heaps / Priority Queues</option>
                    <option value="Tries">Tries</option>
                    <option value="Sorting & Searching">Sorting & Searching</option>
                    <option value="Two Pointers">Two Pointers</option>
                    <option value="Sliding Window">Sliding Window</option>
                    <option value="Dynamic Programming">Dynamic Programming</option>
                    <option value="Greedy Algorithms">Greedy Algorithms</option>
                    <option value="Backtracking">Backtracking</option>
                </select>
            </div>

            <div class="input-group">
                <label for="questions">Question Solved 💡</label>
                <input type="text" id="questions" name="questions" placeholder="e.g., Merge Intervals" required>
            </div>

            <div class="input-group">
                <label for="algorithms">Algorithm Implemented ⚙️</label>
                <input type="text" id="algorithms" name="algorithms" placeholder="e.g., Sorting" required>
            </div>

            <button type="submit">Update Today's Day 🚀</button>
        </form>
    </div>
</body>

</html>